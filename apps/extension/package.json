{
  "name": "@mosaiclynx/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mosaiclynx/chain-nem": "workspace:*",
    "@mosaiclynx/chain-symbol": "workspace:*",
    "@mosaiclynx/core": "workspace:*",
    "@mosaiclynx/provider-api": "workspace:*",
    "@mosaiclynx/profile-backup": "workspace:*",
    "@mosaiclynx/relay-protocol": "workspace:*",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@nemnesia/symbol-sdk": "3.3.2-pure.2",
    "@noble/hashes": "2.2.0",
    "i18next": "^26.3.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@types/chrome": "^0.0.307",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.6"
  },
  "scripts": {
    "build": "pnpm --filter @mosaiclynx/release-evidence build && node ../../tools/evidence/embed.mjs && vite build",
    "typecheck": "pnpm --filter @mosaiclynx/core build && pnpm --filter @mosaiclynx/provider-api build && pnpm --filter @mosaiclynx/chain-symbol build && pnpm --filter @mosaiclynx/chain-nem build && pnpm --filter @mosaiclynx/profile-backup build && tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  }
}
