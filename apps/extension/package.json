{
  "name": "@mosaic-lynx/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@mosaic-lynx/chain-nem": "workspace:*",
    "@mosaic-lynx/chain-symbol": "workspace:*",
    "@mosaic-lynx/core": "workspace:*",
    "@mosaic-lynx/provider-api": "workspace:*",
    "@mosaic-lynx/sss-adapter": "workspace:*",
    "@nemnesia/symbol-sdk": "3.3.2-pure.2",
    "@noble/hashes": "2.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@types/chrome": "^0.0.307",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.6"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "pnpm --filter @mosaic-lynx/core build && pnpm --filter @mosaic-lynx/provider-api build && pnpm --filter @mosaic-lynx/chain-symbol build && pnpm --filter @mosaic-lynx/chain-nem build && pnpm --filter @mosaic-lynx/sss-adapter build && tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  }
}
