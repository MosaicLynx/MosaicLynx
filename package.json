{
  "name": "mosaiclynx",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:extension": "pnpm --filter @mosaiclynx/extension build",
    "test:unit": "pnpm test",
    "test:integration": "pnpm build",
    "test:e2e": "pnpm --filter @mosaiclynx/extension test",
    "evidence:collect": "pnpm --filter @mosaiclynx/release-evidence build && node tools/evidence/index.mjs collect",
    "evidence:manifest": "pnpm --filter @mosaiclynx/release-evidence build && node tools/evidence/index.mjs manifest",
    "evidence:sign": "pnpm --filter @mosaiclynx/release-evidence build && node tools/evidence/index.mjs sign",
    "evidence:verify": "pnpm --filter @mosaiclynx/release-evidence build && node tools/evidence/index.mjs verify",
    "evidence:gate": "pnpm --filter @mosaiclynx/release-evidence build && node tools/evidence/index.mjs gate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^9.39.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.16"
  }
}
